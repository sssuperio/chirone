# Sync API base for local `pnpm run dev`.
# Use `http://localhost:8090` when the Go server runs separately.
# Use `/` only when the frontend is built into the same Chirone binary.
PUBLIC_CHIRONE_SYNC_API_BASE=http://localhost:8090

# Optional: allow users to override the sync API base from the frontend settings page.
# Default should stay `false` for production builds.
PUBLIC_CHIRONE_ALLOW_SYNC_API_BASE_OVERRIDE=false

# Logical project name persisted on the sync backend.
PUBLIC_CHIRONE_SYNC_PROJECT=default
